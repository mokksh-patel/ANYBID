PORT=3000
JWT_SECRET=change-this-to-a-long-random-string

# MySQL (use docker-compose or local install)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=anybid
DB_PASSWORD=anybid_secret
DB_NAME=anybid

# Platform owner / admin notifications
ADMIN_EMAIL=mokkshpatel@gmail.com
